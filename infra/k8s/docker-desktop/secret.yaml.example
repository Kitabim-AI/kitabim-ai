apiVersion: v1
kind: Secret
metadata:
  name: kitabim-secrets
  namespace: kitabim
type: Opaque
stringData:
  GEMINI_API_KEY: "your_google_gemini_api_key"
  # Authentication secrets (required for auth features)
  JWT_SECRET_KEY: "your_256_bit_random_secret_key_min_32_chars"
  GOOGLE_CLIENT_ID: "your_google_oauth_client_id.apps.googleusercontent.com"
  GOOGLE_CLIENT_SECRET: "your_google_oauth_client_secret"
  # Comma-separated list of emails that should be auto-promoted to admin on signup
  ADMIN_EMAILS: "admin@example.com"
