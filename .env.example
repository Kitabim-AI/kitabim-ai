# Gemini AI API Key (Get it from https://aistudio.google.com/)
GEMINI_API_KEY=your_google_gemini_api_key_here

# Gemini model name for OCR/Text extraction
GEMINI_MODEL_NAME=gemini-3-flash-preview

# Categorization model name for metadata processing
GEMINI_CATEGORIZATION_MODEL=gemini-3-flash-preview

# Embedding model name for vector search
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001

# MongoDB Connection String
MONGODB_URL=mongodb://localhost:27017
MONGODB_DATABASE=kitabim_ai_db

# Concurrency Control for PDF processing
MAX_PARALLEL_PAGES=5

# OCR Provider: "gemini" or "local"
OCR_PROVIDER=gemini

# Local OCR API URL (only used if OCR_PROVIDER is "local")
LOCAL_OCR_URL=http://localhost:8001

# OCR retry settings
OCR_MAX_RETRIES=4

# RAG settings
RAG_SCORE_THRESHOLD=0.35
RAG_TOP_K=12
RAG_FALLBACK_K=8
RAG_MAX_CHARS_PER_BOOK=4000

# Shared data directory for uploads/covers (relative to repo root)
DATA_DIR=./data

# LangChain (optional)
LANGCHAIN_CACHE=false
LANGCHAIN_TRACING=false
LANGCHAIN_PROJECT=kitabim-local
RAG_EVAL_ENABLED=false

# LLM Circuit Breaker
LLM_CB_FAILURE_THRESHOLD=5
LLM_CB_RECOVERY_SECONDS=30
LLM_CB_HALF_OPEN_MAX_CALLS=1

# Queue / Workers (required)
REDIS_URL=redis://localhost:6379/0
QUEUE_MAX_JOBS=2
QUEUE_JOB_TIMEOUT=1800
QUEUE_MAX_RETRIES=3
JOB_LOCK_TTL_SECONDS=1800
