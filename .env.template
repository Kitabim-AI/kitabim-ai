# .env — Local Development Configuration Template
# ------------------------------------------------------------------
# NOTE: This file is ONLY used when running scripts, tests, or services
# LOCALLY (outside of Kubernetes).
#
# When running in Kubernetes (Docker Desktop / minikube), configuration
# is loaded from `k8s/local/configmap.yaml` and `k8s/local/secrets.yaml`.
# ------------------------------------------------------------------

# --- Database (Local Host) ---
# Used by migration scripts and local runner
# SECURITY: Replace 'USERNAME' with your actual database username
DATABASE_URL=postgresql://USERNAME@localhost:5432/kitabim-ai

# Connection Pool Configuration
# Backend pool: Serves web requests (higher priority)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=15
# Backend total: 10+15=25 max connections

# Worker pool: Background processing (limited to reserve connections for backend)
WORKER_DB_POOL_SIZE=5
WORKER_DB_MAX_OVERFLOW=10
# Worker total: 5+10=15 max connections

# Rationale:
# - Backend: 10+15=25 max handles API requests and admin dashboard (priority).
# - Worker: 5+10=15 max handles background jobs (limited to avoid starving backend).
# - Total: 40 connections max (Safe for standard PostgreSQL or Cloud SQL limits).
# - This ensures backend always has available connections for user requests.
#
# Production benefit: Prevents "QueuePool limit reached" errors while prioritizing user-facing requests.

# --- Redis (Local Host) ---
REDIS_URL=redis://localhost:6379/0

# --- Redis Cache Configuration ---
# Enable/disable caching globally
REDIS_CACHE_ENABLED=true
# Default TTL for cached items (seconds)
REDIS_CACHE_DEFAULT_TTL=300
# Cache key prefix (namespace)
REDIS_CACHE_KEY_PREFIX=kitabim:cache:

# --- Per-Feature Cache TTLs (seconds) ---
CACHE_TTL_BOOKS=900
CACHE_TTL_SYSTEM_CONFIG=600
CACHE_TTL_CATEGORIES=900
CACHE_TTL_RAG_QUERY=3600
CACHE_TTL_USER_PROFILE=300
CACHE_TTL_STATS=120
CACHE_TTL_SUMMARY_SEARCH=1800
CACHE_TTL_PROVERBS=86400

# --- Cache Behavior ---
# Skip cache for admin users (always real-time data)
CACHE_SKIP_FOR_ADMINS=true
# Maximum number of keys to cache per pattern (managed by Redis LRU)
CACHE_MAX_KEYS_PER_PATTERN=1000


# --- Gemini API (Required for AI features) ---
# SECURITY: Never commit real API keys to version control
# Get your key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=REPLACE_WITH_YOUR_ACTUAL_GEMINI_API_KEY
# NOTE: All model names (OCR, chat, categorization, embedding) are configured
# exclusively via the system_configs table in the database. See seeds.py.

# --- Authentication ---
# SECURITY: Generate a secure random secret key (minimum 32 characters, recommended 64+)
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=GENERATE_SECURE_RANDOM_SECRET_MIN_64_CHARS
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- IP Hashing Salt (Required for Privacy Compliance) ---
# SECURITY: Generate a secure random salt for hashing IP addresses
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
IP_SALT=GENERATE_SECURE_RANDOM_SALT_MIN_32_CHARS

# --- Google OAuth (Optional) ---
# Get credentials from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:30080/api/auth/google/callback

# --- Facebook OAuth (Optional) ---
FACEBOOK_CLIENT_ID=your_facebook_client_id_here
FACEBOOK_CLIENT_SECRET=your_facebook_client_secret_here
FACEBOOK_REDIRECT_URI=http://localhost:30080/api/auth/facebook/callback

# --- Twitter OAuth (Optional) ---
TWITTER_CLIENT_ID=your_twitter_client_id_here
TWITTER_CLIENT_SECRET=your_twitter_client_secret_here
TWITTER_REDIRECT_URI=http://localhost:30080/api/auth/twitter/callback

# --- CORS Origins (Security) ---
# Comma-separated list of allowed frontend origins
# SECURITY: Only add origins you trust
CORS_ORIGINS=http://localhost:3000,http://localhost:30080

# --- Environment ---
# Set to 'production' for production deployment (enables strict security)
ENVIRONMENT=development

# --- Auth Behavior ---
DEFAULT_USER_ROLE=reader
ADMIN_EMAILS=
LOG_LEVEL=DEBUG
MAINTENANCE_RETENTION_DAYS=7

# --- Storage ---
STORAGE_BACKEND=gcs
GCS_DATA_BUCKET=your-gcs-data-bucket-name
GCS_MEDIA_BUCKET=your-gcs-media-bucket-name
# Local absolute path for data volume (still used for temp storage)
# SECURITY: Update this to your actual project path
DATA_DIR=/path/to/your/project/kitabim-ai/data

# --- Processing (Local Defaults) ---
MAX_PARALLEL_PAGES=6
MAX_PARALLEL_SPELL_CHECK=6
MAX_CONCURRENT_SPELL_CHECK_BOOKS=2
MAX_PARALLEL_AUTO_CORRECT=10
EMBED_BATCH_SIZE=50
OCR_MAX_RETRIES=4
LLM_CB_FAILURE_THRESHOLD=10
LLM_CB_RECOVERY_SECONDS=60
LLM_CB_HALF_OPEN_MAX_CALLS=1
LLM_CB_COOLING_PERIOD=60

# --- LangChain / Observability ---
LANGCHAIN_CACHE=false
LANGCHAIN_TRACING=false
LANGCHAIN_PROJECT=

# --- RAG Settings ---
RAG_SCORE_THRESHOLD=0.50
RAG_TOP_K=16
RAG_FALLBACK_K=10
RAG_MAX_CHARS_PER_BOOK=12000

# --- Book Summary / Hierarchical RAG Settings ---
SUMMARY_TOP_K=5
SUMMARY_THRESHOLD=0.30
SUMMARY_MAX_CHARS=15000

# --- Queue Settings ---
QUEUE_MAX_JOBS=2
QUEUE_JOB_TIMEOUT=7200
QUEUE_MAX_RETRIES=3
RAG_EVAL_ENABLED=true

# --- Pipeline Feature Flags ---
# Enable/disable word indexing for spell-check
# Set to 'false' to skip word index scanner in the pipeline
ENABLE_WORD_INDEX=true



# --- Chunking Settings ---
CHUNK_SIZE=1500
CHUNK_OVERLAP=300
