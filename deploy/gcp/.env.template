# ============================================================
# Kitabim AI — Production Environment Variables
# Copy this to .env and fill in all values marked FILL_IN
# Keep .env secret — never commit it to git
# ============================================================

# ─── Database (Cloud SQL private IP) ────────────────────────
DATABASE_URL=postgresql://kitabim:FILL_IN@10.158.0.5:5432/kitabim-ai

# Connection Pool (Production-Optimized for Cloud SQL)
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=5
# Rationale:
# - Cloud SQL typically has 50 max_connections on basic tiers
# - Per service: 5+5=10 max connections
# - Both services (backend + worker): 20 total
# - Leaves 30 connections (60% headroom) for bursts and maintenance
# - Typical usage: 5-8 active connections
# - If you upgrade Cloud SQL to 100+ connections, you can increase these

# ─── Redis (in-container, do not change) ────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Storage ────────────────────────────────────────────────
STORAGE_BACKEND=gcs
GCS_DATA_BUCKET=ai-kitabim-prod-data-bkt
GCS_MEDIA_BUCKET=ai-kitabim-prod-media-bkt
DATA_DIR=/app/data
# GOOGLE_APPLICATION_CREDENTIALS is set in docker-compose.yml

# ─── Gemini API ─────────────────────────────────────────────
GEMINI_API_KEY=FILL_IN
# Note: Model configuration is now in system_configs table:
#   - gemini_ocr_model (OCR processing)
#   - gemini_chat_model (chat responses)
#   - gemini_categorization_model (category routing)
# Old env vars removed - use database config instead
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001

# ─── JWT Authentication ──────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=FILL_IN
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Google OAuth ────────────────────────────────────────────
GOOGLE_CLIENT_ID=FILL_IN
GOOGLE_CLIENT_SECRET=FILL_IN
GOOGLE_REDIRECT_URI=https://kitabim.ai/api/auth/google/callback

# ─── Admin ───────────────────────────────────────────────────
# Comma-separated list of email addresses with admin access
ADMIN_EMAILS=FILL_IN

# ─── Processing ──────────────────────────────────────────────
MAX_PARALLEL_PAGES=4
OCR_MAX_RETRIES=4

# ─── RAG Settings ────────────────────────────────────────────
RAG_SCORE_THRESHOLD=0.50
RAG_TOP_K=16
RAG_FALLBACK_K=10
RAG_MAX_CHARS_PER_BOOK=6000
RAG_RERANK_ENABLED=true
RAG_RERANK_TOP_N=6

# ─── Chunking ────────────────────────────────────────────────
CHUNK_SIZE=500
CHUNK_OVERLAP=100

# ─── Queue / Worker ──────────────────────────────────────────
QUEUE_MAX_JOBS=2
QUEUE_JOB_TIMEOUT=7200
QUEUE_MAX_RETRIES=3

# ─── LLM Circuit Breaker ─────────────────────────────────────
LLM_CB_FAILURE_THRESHOLD=10
LLM_CB_RECOVERY_SECONDS=60
LLM_CB_HALF_OPEN_MAX_CALLS=1
LLM_CB_COOLING_PERIOD=60

# ─── Logging ─────────────────────────────────────────────────
LOG_LEVEL=INFO
